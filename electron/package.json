{
  "name": "freefy-desktop",
  "version": "1.0.0",
  "description": "Freefy - 免费音乐桌面版",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.freefy.desktop",
    "productName": "Freefy",
    "directories": {
      "output": "../outputs/desktop"
    },
    "win": {
      "target": ["nsis"],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "main.js",
      "preload.js",
      "../server/**/*",
      "../client/dist/**/*",
      "../node_modules/**/*",
      "!../node_modules/.cache"
    ]
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
